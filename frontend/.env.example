# Backend API URL (optional; default http://localhost:5292)
# VITE_API_URL=http://localhost:5292

# Spotify Web API token (required for Spotify search & top tracks).
# Get token: https://developer.spotify.com/documentation/web-api/concepts/authorization
# Token expires in ~1 hour; refresh and update this value when needed.
VITE_SPOTIFY_TOKEN=your_spotify_bearer_token_here
